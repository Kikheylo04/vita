# ── Supabase ─────────────────────────────────────────────
# Crear proyecto gratuito en https://supabase.com
# Settings > API > Project URL y anon public key
VITE_SUPABASE_URL=https://xxxxxxxxxxxx.supabase.co
VITE_SUPABASE_ANON_KEY=eyxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ── WhatsApp ─────────────────────────────────────────────
# Número sin + ni espacios (código país + número)
VITE_WHATSAPP_PHONE=5215512345678
# Mensaje predeterminado al abrir WhatsApp
VITE_WHATSAPP_MSG=Hola, me gustaría hacer una reservación en VITA.

# ── EmailJS ───────────────────────────────────────────────
# Crear cuenta gratuita en https://www.emailjs.com
# 1. Crear un "Email Service" (Gmail, Outlook, etc.) → copiar Service ID
# 2. Crear dos "Email Templates": uno para reservaciones, otro para contacto
# 3. Copiar el Public Key desde Account > API Keys
VITE_EMAILJS_SERVICE_ID=service_xxxxxxx
VITE_EMAILJS_TEMPLATE_RESERVA=template_xxxxxxx
VITE_EMAILJS_TEMPLATE_CONTACT=template_xxxxxxx
VITE_EMAILJS_PUBLIC_KEY=xxxxxxxxxxxxxxxxxxxx
